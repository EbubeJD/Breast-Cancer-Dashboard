# ============= Application =============
DASH_DEBUG=False
DASH_PORT=8050
PYTHONUNBUFFERED=1

# ============= Performance =============
CACHE_ENABLED=True
CACHE_TTL_SECONDS=3600

# ============= Security =============
# Set DASH_DEBUG=True only for local development
# In production (Railway), this is automatically set to False

# ============= Logging =============
LOG_LEVEL=INFO

# ============= Data =============
# Path to METABRIC data (defaults to data/ directory)
DATA_PATH=data/

# ============= Optional: Future Features =============
# DATABASE_URL=postgresql://user:password@localhost:5432/metabric
# SENTRY_DSN=
# DATADOG_API_KEY=
